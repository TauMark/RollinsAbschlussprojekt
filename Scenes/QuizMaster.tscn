[sub_resource type="GDScript" id="GDScript_6vsac"]
script/source = "extends Node2D

# ── Referenzen ──────────────────────────────────────────────────────────────
@onready var anim            = $Visual/AnimationPlayer
@onready var bubble          = $SpeechBubble
@onready var bubble_label    = $SpeechBubble/PanelContainer/MarginContainer/Label

# Quiz-UI – wird zur Laufzeit per get_node_or_null gesucht (crash-sicher)
var quiz_panel      : Control  = null
var question_label  : Label    = null
var answer_buttons  : Array    = []
var feedback_label  : Label    = null

# ── Einstellungen ────────────────────────────────────────────────────────────
@export var theme = \"\"

const ROOM_CATEGORY_MAP = {
	\"Room1\": \"Wirtschaft\",
	\"Room2\": \"Programmierung Pseudocode\",
	\"Room3\": \"Datenbank - SQL\",
	\"Room4\": \"UML\",
}

const QUESTIONS_PATH = \"res://data/questions.json\"

# ── Zustand ──────────────────────────────────────────────────────────────────
var all_questions    : Array      = []
var current_question : Dictionary = {}

var player_near  = false
var can_interact = false
var quiz_active  = false

var dialog       = [\"Hey! Drücke E um fortzufahren\"]
var dialog_index = 0

# ── _ready ───────────────────────────────────────────────────────────────────
func _ready():
	anim.play(\"idle\")
	bubble.visible = false

	_bind_quiz_ui()
	_load_questions()

	$InteractionArea.body_entered.connect(_on_body_entered)
	$InteractionArea.body_exited.connect(_on_body_exited)

# ── Quiz-UI per get_node_or_null binden ───────────────────────────────────────
func _bind_quiz_ui():
	quiz_panel     = get_node_or_null(\"QuizPanel\")
	question_label = get_node_or_null(\"QuizPanel/VBox/QuestionLabel\")
	feedback_label = get_node_or_null(\"QuizPanel/VBox/FeedbackLabel\")

	answer_buttons.clear()
	for btn_name in [\"BtnA\", \"BtnB\", \"BtnC\", \"BtnD\"]:
		var btn = get_node_or_null(\"QuizPanel/VBox/\" + btn_name)
		answer_buttons.append(btn)   # kann null sein, wird unten geprüft

	# Debug: zeigt fehlende Nodes in der Godot-Konsole
	if quiz_panel == null:
		push_warning(\"Quizmaster: 'QuizPanel' nicht gefunden. Quiz deaktiviert.\")
	if question_label == null:
		push_warning(\"Quizmaster: 'QuizPanel/VBox/QuestionLabel' nicht gefunden.\")
	if feedback_label == null:
		push_warning(\"Quizmaster: 'QuizPanel/VBox/FeedbackLabel' nicht gefunden.\")
	for i in answer_buttons.size():
		if answer_buttons[i] == null:
			push_warning(\"Quizmaster: Button %s nicht gefunden.\" % [\"BtnA\",\"BtnB\",\"BtnC\",\"BtnD\"][i])

	# Buttons verbinden (nur wenn vorhanden)
	for i in answer_buttons.size():
		if answer_buttons[i] != null:
			answer_buttons[i].pressed.connect(_on_answer_pressed.bind(i))

	# Panel verstecken (nur wenn vorhanden)
	if quiz_panel != null:
		quiz_panel.visible = false
	if feedback_label != null:
		feedback_label.visible = false

# ── Fragen laden ─────────────────────────────────────────────────────────────
func _load_questions():
	if not FileAccess.file_exists(QUESTIONS_PATH):
		push_error(\"Quizmaster: questions.json nicht gefunden unter \" + QUESTIONS_PATH)
		return
	var file   = FileAccess.open(QUESTIONS_PATH, FileAccess.READ)
	var parsed = JSON.parse_string(file.get_as_text())
	file.close()
	if typeof(parsed) == TYPE_ARRAY:
		all_questions = parsed
	else:
		push_error(\"Quizmaster: JSON konnte nicht geparst werden.\")

# ── Zufällige Frage für Kategorie holen ──────────────────────────────────────
func _get_random_question(category: String) -> Dictionary:
	var pool: Array = []
	for q in all_questions:
		if q.get(\"category\", \"\") == category:
			pool.append(q)
	if pool.is_empty():
		return {}
	pool.shuffle()
	return pool[0]

# ── Quiz starten ─────────────────────────────────────────────────────────────
func _start_quiz():
	if quiz_panel == null or question_label == null:
		push_warning(\"Quizmaster: QuizPanel fehlt – Quiz kann nicht gestartet werden.\")
		return

	if not ROOM_CATEGORY_MAP.has(theme):
		return

	var category = ROOM_CATEGORY_MAP[theme]
	current_question = _get_random_question(category)
	if current_question.is_empty():
		push_warning(\"Quizmaster: Keine Fragen für Kategorie '\" + category + \"' gefunden.\")
		return

	bubble.visible         = false
	quiz_panel.visible     = true
	quiz_active            = true
	if feedback_label != null:
		feedback_label.visible = false

	question_label.text = current_question.get(\"question\", \"???\")

	var answers: Array = current_question.get(\"answers\", [])
	for i in answer_buttons.size():
		var btn = answer_buttons[i]
		if btn == null:
			continue
		if i < answers.size():
			btn.text     = answers[i].get(\"label\", \"\") + \") \" + answers[i].get(\"text\", \"\")
			btn.visible  = true
			btn.disabled = false
		else:
			btn.visible = false

# ── Antwort ausgewählt ────────────────────────────────────────────────────────
func _on_answer_pressed(index: int):
	var answers: Array = current_question.get(\"answers\", [])
	if index >= answers.size():
		return

	var chosen  = answers[index]
	var correct = chosen.get(\"correct\", false)

	for btn in answer_buttons:
		if btn != null:
			btn.disabled = true

	if feedback_label != null:
		feedback_label.visible = true
		if correct:
			feedback_label.text = \"✔ Richtig! +\" + str(current_question.get(\"points\", 1)) + \" Punkt(e)\"
		else:
			var correct_text = \"\"
			for a in answers:
				if a.get(\"correct\", false):
					correct_text = a.get(\"label\", \"\") + \") \" + a.get(\"text\", \"\")
			feedback_label.text = \"✘ Falsch! Richtig wäre: \" + correct_text

	if correct:
		_award_points(current_question.get(\"points\", 1))
		play_confetti()
		print(\"+1 point\")

	await get_tree().create_timer(2.5).timeout
	_close_quiz()

# ── Quiz schließen ────────────────────────────────────────────────────────────
func _close_quiz():
	if quiz_panel != null:
		quiz_panel.visible = false
	quiz_active = false

# ── Punkte vergeben ───────────────────────────────────────────────────────────
func _award_points(amount: int):
	var players = get_tree().get_nodes_in_group(\"Player\")
	if players.is_empty():
		return
	var player = players[0]
	if player.has_method(\"add_points\"):
		player.add_points(amount)

# ── Eingabe ───────────────────────────────────────────────────────────────────
func _process(_delta):
	if not player_near:
		return

	if quiz_active and Input.is_action_just_pressed(\"ui_cancel\"):
		_close_quiz()
		return

	if Input.is_action_just_pressed(\"interaction_next_sentence\"):
		if quiz_active:
			return

		if theme in ROOM_CATEGORY_MAP:
			_start_quiz()
		else:
			_setup_greeting_dialog()
			if dialog_index < dialog.size():
				bubble.visible    = true
				bubble_label.text = dialog[dialog_index]
				dialog_index     += 1
			else:
				bubble.visible = false

# ── Begrüßungsdialog ──────────────────────────────────────────────────────────
func _setup_greeting_dialog():
	match theme:
		\"start\":
			dialog = [
				\"Willkommen im Startraum!\",
				\"Hier lernst du die Grundlagen.\",
				\"Sammle 10 Punkte indem du Fragen beantwortest!\",
				\"Rechts von mir sind SQL-Fragen\",
				\"Oben ist Wirtschaft\",
				\"Unten ist UML\",
				\"Links ist Pseudocode\",
				\"Wenn du alle Punkte hast\",
				\"Dann geh in die Tür links von mir\"
			]
		\"Room1\": dialog = [\"Drücke E für eine Wirtschafts-Frage!\"]
		\"Room2\": dialog = [\"Drücke E für eine Pseudocode-Frage!\"]
		\"Room3\": dialog = [\"Drücke E für eine SQL-Frage!\"]
		\"Room4\": dialog = [\"Drücke E für eine UML-Frage!\"]

# ── Kollision ─────────────────────────────────────────────────────────────────
func _on_body_entered(body):
	if body.is_in_group(\"Player\"):
		player_near  = true
		can_interact = true
		dialog_index = 0
		_setup_greeting_dialog()
		bubble.visible    = true
		bubble_label.text = dialog[0]

func _on_body_exited(body):
	if body.is_in_group(\"Player\"):
		player_near  = false
		can_interact = false
		bubble.visible = false
		if quiz_active:
			_close_quiz()
			

@onready var confetti = $Control/GPUParticles2D
		
		
func play_confetti():
	confetti.emitting = true
	await get_tree().create_timer(2.0).timeout
	confetti.emitting = false
"

