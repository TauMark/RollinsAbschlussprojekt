[ext_resource type="Texture2D" uid="uid://b08noggrphrox" path="res://Assets/Char/Quizmaster.png" id="1_6vsac"]

[sub_resource type="GDScript" id="GDScript_6vsac"]
script/source = "extends Node2D

@onready var anim = $Visual/AnimationPlayer
@onready var speech_label = Label.new()

func _ready():
	anim.play(\"idle\")

	speech_label.text = \"\"
	speech_label.visible = false
	speech_label.position = Vector2(0, -50)
	add_child(speech_label)
	
	$InteractionArea.body_entered.connect(_on_body_entered)
	$InteractionArea.body_exited.connect(_on_body_exited)

var can_interact = false

func _on_body_entered(body):
	if body.is_in_group(\"Player\"):  # Spieler muss in Gruppe \"player\" sein
		can_interact = true
		show_speech(\"I hate u\")

func _on_body_exited(body):
	if body.is_in_group(\"Player\"):
		can_interact = false

func show_speech(text: String):
	speech_label.text = text
	speech_label.visible = true
	await get_tree().create_timer(2.0).timeout
	speech_label.visible = false
"

